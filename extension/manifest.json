{
  "manifest_version": 3,
  "name": "subtitler",
  "version": "0.1.0",
  "description": "Chrome extension that toggles subtitle-style Japanese translations under English sentences (Cmd+Shift+Y).",
  "minimum_chrome_version": "138",
  "action": {
    "default_title": "subtitler: toggle translations (Cmd+Shift+Y)"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-translation": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Toggle translations on/off"
    }
  }
}

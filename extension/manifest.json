{
  "manifest_version": 3,
  "name": "subtitler",
  "version": "1.0.2",
  "description": "英語の各文の下に日本語訳を字幕のように表示する Chrome 拡張機能。ショートカット（Alt+Shift+Y）でオン／オフを切り替えできます。",
  "minimum_chrome_version": "138",
  "action": {
    "default_title": "subtitler: 日本語字幕の表示を切り替え（Alt+Shift+Y）",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-translation": {
      "suggested_key": {
        "default": "Alt+Shift+Y",
        "mac": "Alt+Shift+Y"
      },
      "description": "翻訳の表示／非表示を切り替え"
    }
  }
}

{
  "manifest_version": 3,
  "name": "subtitler",
  "version": "0.1.1",
  "description": "Chrome extension that toggles subtitle-style Japanese translations under English sentences (Alt+Shift+Y).",
  "minimum_chrome_version": "138",
  "action": {
    "default_title": "subtitler: toggle translations (Alt+Shift+Y)",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-translation": {
      "suggested_key": {
        "default": "Alt+Shift+Y",
        "mac": "Alt+Shift+Y"
      },
      "description": "Toggle translations on/off"
    }
  }
}
